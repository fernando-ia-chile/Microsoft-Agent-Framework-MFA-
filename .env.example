# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI (examples 02, 04) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-api-key-here...
# Optional: choose a different model (default used in examples: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ── Azure OpenAI (examples 03, 04) ───────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=...your-azure-openai-key-here...
# The deployment name you created in Azure OpenAI Studio
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# API version – check https://learn.microsoft.com/en-us/azure/ai-services/openai/reference
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Azure AI Project / Agent Service (example 05) ────────────────────────────
AZURE_AI_PROJECT_CONNECTION_STRING=...your-connection-string-here...

# ── Semantic Kernel (example 05) ─────────────────────────────────────────────
# Reuses OPENAI_API_KEY and AZURE_OPENAI_* variables above.

# ── General ──────────────────────────────────────────────────────────────────
# Set to "true" to print verbose debug output in examples
DEBUG=false
