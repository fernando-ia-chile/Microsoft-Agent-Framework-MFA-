# =============================================================================
# Configuración de Azure OpenAI (obligatoria para ambos escenarios)
# =============================================================================
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4-mini
AZURE_OPENAI_API_VERSION=preview

# Opcional: Nombre de conexión específico para Azure OpenAI en su proyecto.
AOAI_CONNECTION_NAME=gpt-5.4-mini

# =============================================================================
# Configuración del servidor MCP
# =============================================================================
# Puertos para servidores MCP locales
MCP_WEATHER_SERVER_PORT=8001
MCP_FILE_SERVER_PORT=8002
MCP_DATABASE_SERVER_PORT=8003

# =============================================================================
# Configuración del agente
# =============================================================================
# Temperatura y otros parámetros del modelo
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=1500

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
